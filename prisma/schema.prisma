// Database TERPISAH dari Coin Store — landing page ini punya databasenya sendiri.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Singleton (cuma 1 row, id selalu 1) buat setting umum server & tampilan landing page.
model ServerInfo {
  id Int @id @default(1)

  serverName  String @default("GoKaizen Network")
  description String @db.Text @default("")
  logoUrl     String? @db.Text // path ke file logo yang diupload admin (di /public/uploads)

  displayIp   String @default("play.example.com")
  displayPort Int    @default(25565)

  pingHost String @default("play.example.com")
  pingPort Int    @default(25565)

  discordInviteUrl String? @db.Text

  updatedAt DateTime @updatedAt

  @@map("landing_server_info")
}

// Tombol/link yang muncul di landing page (vote, store, ban list, discord, custom).
model LinkItem {
  id    String  @id @default(cuid())
  label String
  url   String  @db.Text
  type  String  @default("custom") // "vote" | "store" | "banlist" | "discord" | "custom"

  sortOrder Int     @default(0)
  visible   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_links")
}

// Feature highlight di section "Kenapa Main di Sini" (kelola dari admin)
model FeatureHighlight {
  id          String @id @default(cuid())
  title       String
  description String @db.Text
  icon        String @default("sparkles") // nama icon lucide-react, dipilih dari daftar terbatas
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())

  @@map("landing_features")
}

// Galeri screenshot server. Bisa diupload admin ATAU member forum yang login
// (uploadedById null = diupload admin, terisi = diupload member tertentu).
model GalleryImage {
  id        String  @id @default(cuid())
  imagePath String  @db.Text
  caption   String?
  sortOrder Int     @default(0)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("landing_gallery")
}

// ===================== FORUM KOMUNITAS =====================

model User {
  id           String @id @default(cuid())
  username     String @unique
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())

  threads     ForumThread[]
  replies     ForumReply[]
  threadLikes ThreadLike[]
  replyLikes  ReplyLike[]
  sessions    Session[]
  galleryImages GalleryImage[]

  @@map("forum_users")
}

// Session token disimpan di DB (bukan JWT) biar bisa di-revoke kapan aja
// (misal logout paksa), pola yang sama dipakai di banyak app sederhana.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("forum_sessions")
}

model ForumCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)

  threads ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id      String @id @default(cuid())
  title   String
  content String @db.Text

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  pinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies ForumReply[]
  likes   ThreadLike[]

  @@index([categoryId])
  @@map("forum_threads")
}

model ForumReply {
  id      String @id @default(cuid())
  content String @db.Text

  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes ReplyLike[]

  @@index([threadId])
  @@map("forum_replies")
}

model ThreadLike {
  id       String @id @default(cuid())
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([threadId, userId])
  @@map("forum_thread_likes")
}

model ReplyLike {
  id      String @id @default(cuid())
  replyId String
  reply   ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([replyId, userId])
  @@map("forum_reply_likes")
}
